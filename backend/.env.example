APP_NAME=Eleven Nodes API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# Central LLM configuration — used for workflow execution, instruction generation, etc.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_TOP_P=1
LLM_MAX_TOKENS=4096
LLM_PRESENCE_PENALTY=0
LLM_FREQUENCY_PENALTY=0
# LLM_SEED=
# LLM_STREAM=false

# Microsoft Agent Framework provider credentials
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Used when LLM_PROVIDER is azure / azure-openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# Azure deployment name (used as model when LLM_MODEL is not set)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
