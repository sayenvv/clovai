# Project-level environment (loaded by backend from repo root)
# Copy to .env and fill in your provider credentials.

# --- Azure OpenAI (auto-detected when endpoint + key are set) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# Deployment name in Azure (shown in navbar as the active model)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Or OpenAI ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# --- Optional overrides (defaults apply when omitted) ---
# LLM_PROVIDER=azure-openai
# LLM_MODEL=gpt-4o
# LLM_TEMPERATURE=0.7
# LLM_TOP_P=1
# LLM_MAX_TOKENS=4096
